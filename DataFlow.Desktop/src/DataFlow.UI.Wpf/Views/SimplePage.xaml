<UserControl x:Class="DataFlow.UI.Wpf.Views.SimplePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="{StaticResource BgSurfaceBrush}">
    <StackPanel Margin="28,28,28,0">
        <TextBlock x:Name="TitleText" FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   FontFamily="Segoe UI" TextWrapping="Wrap" />
        <TextBlock x:Name="SubtitleText" Margin="0,10,0,0" FontSize="13"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontFamily="Segoe UI" TextWrapping="Wrap" MaxWidth="760" />
        <Border Margin="0,20,0,0" Style="{StaticResource CardStyle}">
            <TextBlock x:Name="BodyText" Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13" FontFamily="Segoe UI" TextWrapping="Wrap" />
        </Border>
    </StackPanel>
</UserControl>
