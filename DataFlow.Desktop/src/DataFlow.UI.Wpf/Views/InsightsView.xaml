<UserControl x:Class="DataFlow.UI.Wpf.Views.InsightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="{StaticResource BgSurfaceBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,20,28,16"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="AI Insights" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI" />
                    <TextBlock Text="Automatically generated insights and recommendations from your data"
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource AccentBgBrush}" BorderBrush="#2D2B6B"
                            BorderThickness="1" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                        <TextBlock Text="✦ 14 new insights" FontSize="12"
                                   Foreground="{StaticResource AccentHoverBrush}" FontFamily="Segoe UI" />
                    </Border>
                    <Button Content="Refresh" Style="{StaticResource GhostButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,16,28,20">
            <StackPanel>
                <!-- Critical insight -->
                <Border Background="#1A0A0A" BorderBrush="#3D1515" BorderThickness="1"
                        CornerRadius="14" Padding="20" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#3D1515" CornerRadius="10" Width="40" Height="40"
                                Margin="0,0,16,0" VerticalAlignment="Top">
                            <TextBlock Text="⚠" FontSize="18" Foreground="{StaticResource RedBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Background="#3D1515" CornerRadius="5" Padding="6,2" Margin="0,0,8,0">
                                    <TextBlock Text="ANOMALY" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource RedBrush}" FontFamily="Segoe UI" />
                                </Border>
                                <TextBlock Text="2 hours ago" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Revenue drop detected in APAC region"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI" />
                            <TextBlock Text="A 23% revenue decline was detected in the APAC region over the last 48 hours. This is 3.2 standard deviations below the expected baseline. Possible causes include seasonal adjustment or data pipeline issues."
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI" Margin="0,6,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Investigate →"
                                Style="{StaticResource GhostButtonStyle}"
                                VerticalAlignment="Top" Margin="16,0,0,0" />
                    </Grid>
                </Border>

                <!-- Positive insight -->
                <Border Background="#0A1A0A" BorderBrush="#153D15" BorderThickness="1"
                        CornerRadius="14" Padding="20" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#153D15" CornerRadius="10" Width="40" Height="40"
                                Margin="0,0,16,0" VerticalAlignment="Top">
                            <TextBlock Text="↑" FontSize="18" Foreground="{StaticResource GreenBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Background="#153D15" CornerRadius="5" Padding="6,2" Margin="0,0,8,0">
                                    <TextBlock Text="TREND" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource GreenBrush}" FontFamily="Segoe UI" />
                                </Border>
                                <TextBlock Text="5 hours ago" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Customer retention rate up 8.3% this quarter"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI" />
                            <TextBlock Text="The 90-day retention rate has improved from 71.2% to 79.5%, driven primarily by the new onboarding flow launched in March. This is the highest retention rate recorded in 18 months."
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI" Margin="0,6,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="View details →"
                                Style="{StaticResource GhostButtonStyle}"
                                VerticalAlignment="Top" Margin="16,0,0,0" />
                    </Grid>
                </Border>

                <!-- Recommendation -->
                <Border Background="{StaticResource BgCardBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                        CornerRadius="14" Padding="20" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource AccentBgBrush}" CornerRadius="10"
                                Width="40" Height="40" Margin="0,0,16,0" VerticalAlignment="Top">
                            <TextBlock Text="✦" FontSize="18" Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Background="{StaticResource AccentBgBrush}" CornerRadius="5"
                                        Padding="6,2" Margin="0,0,8,0">
                                    <TextBlock Text="RECOMMENDATION" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}" FontFamily="Segoe UI" />
                                </Border>
                                <TextBlock Text="1 day ago" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Segment high-value customers for targeted campaigns"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI" />
                            <TextBlock Text="Based on RFM analysis, 12.4% of your customers account for 68% of revenue. Creating a dedicated segment and personalized campaign could increase LTV by an estimated 15-22%."
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI" Margin="0,6,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Apply →"
                                Style="{StaticResource AccentButtonStyle}" Height="34"
                                VerticalAlignment="Top" Margin="16,0,0,0" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
