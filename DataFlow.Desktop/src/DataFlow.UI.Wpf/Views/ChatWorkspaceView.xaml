<UserControl x:Class="DataFlow.UI.Wpf.Views.ChatWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="{StaticResource BgSurfaceBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,16,24,14"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource AccentGradient}" CornerRadius="10"
                            Width="36" Height="36" Margin="0,0,12,0">
                        <TextBlock Text="✦" Foreground="White" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="AI Workspace" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="StatusText" Text="Ready"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="ApiStatusBadge"
                            Background="#0A1A0A" BorderBrush="#153D15" BorderThickness="1"
                            CornerRadius="8" Padding="10,4" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ApiDot" Width="7" Height="7"
                                     Fill="{StaticResource TextMutedBrush}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="ApiStatusText" Text="Checking API…"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Button Content="New Chat" Style="{StaticResource AccentButtonStyle}"
                            Height="32" Click="NewChatBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Messages area -->
        <ScrollViewer Grid.Row="1" x:Name="MessagesScroll"
                      VerticalScrollBarVisibility="Auto" Padding="24,12,24,12">
            <StackPanel x:Name="MessagesPanel">
                <!-- Welcome shown when empty -->
                <StackPanel x:Name="WelcomePanel" HorizontalAlignment="Center" Margin="0,40,0,32">
                    <Border Background="{StaticResource AccentGradient}" CornerRadius="20"
                            Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="✦" Foreground="White" FontSize="28"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="What would you like to analyze?"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                    <TextBlock Text="Upload a file or ask a question about your data"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,6,0,24"/>

                    <!-- Suggestion chips -->
                    <UniformGrid Columns="2" MaxWidth="640">
                        <Border Style="{StaticResource CardStyle}" Margin="4" Cursor="Hand"
                                MouseLeftButtonDown="SuggestionCard_Click" Tag="Summarize the dataset and highlight the top KPIs and trends.">
                            <StackPanel>
                                <TextBlock Text="📊  Summarize dataset" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                <TextBlock Text="Get KPIs, trends, and key statistics"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Margin="4" Cursor="Hand"
                                MouseLeftButtonDown="SuggestionCard_Click" Tag="What are the most important correlations and patterns in the data?">
                            <StackPanel>
                                <TextBlock Text="🔗  Find correlations" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                <TextBlock Text="Discover relationships between columns"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Margin="4" Cursor="Hand"
                                MouseLeftButtonDown="SuggestionCard_Click" Tag="Generate a dashboard layout with KPI cards, bar chart, and trend line.">
                            <StackPanel>
                                <TextBlock Text="⊞  Generate dashboard" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                <TextBlock Text="Create charts and KPI cards automatically"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Margin="4" Cursor="Hand"
                                MouseLeftButtonDown="SuggestionCard_Click" Tag="Detect anomalies and outliers in the dataset and explain them.">
                            <StackPanel>
                                <TextBlock Text="⚠  Detect anomalies" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                <TextBlock Text="Find outliers and unusual patterns"
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Input bar -->
        <Border Grid.Row="2" Padding="24,10,24,16"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">

            <!-- Attached file indicator -->
            <StackPanel>
                <Border x:Name="AttachedFileBadge" Visibility="Collapsed"
                        Background="{StaticResource AccentBgBrush}"
                        BorderBrush="#2D2B6B" BorderThickness="1"
                        CornerRadius="8" Padding="10,5" Margin="0,0,0,8"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📎" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="AttachedFileName"
                                   FontSize="12" Foreground="{StaticResource AccentHoverBrush}"
                                   FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <Button Content="✕" Width="20" Height="20" Margin="8,0,0,0"
                                Background="Transparent" BorderBrush="Transparent"
                                Foreground="{StaticResource TextMutedBrush}"
                                FontSize="11" Cursor="Hand"
                                Click="RemoveAttachment_Click"/>
                    </StackPanel>
                </Border>

                <Border Background="#141928" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="14">
                    <Grid Margin="14,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="📎" Width="32" Height="32"
                                Background="Transparent" BorderBrush="Transparent"
                                Foreground="{StaticResource TextMutedBrush}"
                                FontSize="16" Cursor="Hand" VerticalAlignment="Bottom"
                                Click="AttachFile_Click" ToolTip="Attach CSV, Excel, or PDF"/>
                        <TextBox Grid.Column="1" x:Name="MessageBox"
                                 Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 FontSize="14" FontFamily="Segoe UI"
                                 VerticalAlignment="Center" MinHeight="24" MaxHeight="120"
                                 TextWrapping="Wrap" AcceptsReturn="False"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 KeyDown="MessageBox_KeyDown"
                                 TextChanged="MessageBox_TextChanged"/>
                        <TextBlock x:Name="InputPlaceholder" Grid.Column="1"
                                   Text="Ask anything about your data…"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="14" FontFamily="Segoe UI"
                                   VerticalAlignment="Center" IsHitTestVisible="False"/>
                        <Button Grid.Column="2" x:Name="SendBtn"
                                Width="36" Height="36" VerticalAlignment="Bottom"
                                Background="{StaticResource AccentGradient}"
                                BorderBrush="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="SendBtn_Click" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                            Opacity="{TemplateBinding Opacity}">
                                        <TextBlock Text="↑" Foreground="White" FontSize="16" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
                <TextBlock Text="Enter to send  ·  Shift+Enter for new line  ·  Attach files for AI analysis"
                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                           FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
