<UserControl x:Class="DataFlow.UI.Wpf.Views.ProjectChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="White">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sessions panel -->
            <ColumnDefinition x:Name="SessionsColumn" Width="240"/>
            <!-- Chat area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ SESSIONS PANEL ══════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#F9FAFB"
                BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Panel header -->
                <Border Grid.Row="0" Padding="14,14,14,12"
                        BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ConversationsLabel"
                                   Text="CONVERSATIONS" FontSize="11" FontWeight="Bold"
                                   Foreground="#9CA3AF" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                        <!-- New chat button -->
                        <Border Grid.Column="1" x:Name="NewChatBtnBorder"
                                Width="26" Height="26" CornerRadius="7"
                                Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1"
                                Cursor="Hand" Margin="0,0,4,0"
                                MouseLeftButtonDown="NewChatBtn_Click">
                            <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                                       Foreground="#6366f1"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Collapse button -->
                        <Border Grid.Column="2" x:Name="CollapseBtn"
                                Width="26" Height="26" CornerRadius="7"
                                Background="Transparent" BorderBrush="#E5E7EB" BorderThickness="1"
                                Cursor="Hand" MouseLeftButtonDown="CollapseBtn_Click">
                            <TextBlock x:Name="CollapseBtnText" Text="«" FontSize="12"
                                       Foreground="#9CA3AF"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Sessions list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel x:Name="SessionsList"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ══ CHAT AREA ═══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- Dataset status banner -->
                <RowDefinition Height="Auto"/>
                <!-- Messages -->
                <RowDefinition Height="*"/>
                <!-- Input bar -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Dataset banner -->
            <Border Grid.Row="0" x:Name="DatasetBanner" Height="40"
                    Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="✓" FontSize="14" Foreground="#10B981" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DatasetNameText" FontSize="12" FontWeight="SemiBold"
                               Foreground="#059669" FontFamily="Segoe UI"
                               VerticalAlignment="Center" MaxWidth="280"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="DatasetRowsText" FontSize="11" Foreground="#6EE7B7"
                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="8,0"/>
                    <Border Width="1" Height="14" Background="#A7F3D0" Margin="4,0"/>
                    <TextBlock Text="Dataset loaded — ask anything without re-uploading"
                               FontSize="11" Foreground="#6B7280" FontFamily="Segoe UI"
                               VerticalAlignment="Center" Margin="8,0"/>
                </StackPanel>
            </Border>

            <!-- No dataset banner -->
            <Border Grid.Row="0" x:Name="NoDatasetBanner" Height="40" Visibility="Collapsed"
                    Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="⚠" FontSize="14" Foreground="#F59E0B" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="No dataset uploaded — go to the Project page to upload one first"
                               FontSize="12" Foreground="#92400E" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Messages -->
            <ScrollViewer Grid.Row="1" x:Name="MessagesScroll"
                          VerticalScrollBarVisibility="Auto" Padding="32,28,32,12">
                <StackPanel x:Name="MessagesPanel">
                    <!-- Welcome / empty state -->
                    <StackPanel x:Name="WelcomePanel" HorizontalAlignment="Center" Margin="0,40,0,32">
                        <Border Background="#6366f1" CornerRadius="16"
                                Width="52" Height="52" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="AI" Foreground="White" FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Ask anything about your data"
                                   FontSize="22" FontWeight="Bold" Foreground="#111827"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock Text="Your dataset is loaded. Start a conversation."
                                   FontSize="13" Foreground="#6B7280" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Input bar -->
            <Border Grid.Row="2" Padding="24,10,24,20"
                    BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Background="White">
                <StackPanel>
                    <!-- Attached file chip -->
                    <Border x:Name="AttachedFileBadge" Visibility="Collapsed"
                            Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1"
                            CornerRadius="8" Padding="10,5" Margin="0,0,0,8"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📎" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="AttachedFileName" FontSize="12"
                                       Foreground="#6366f1" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            <Button Content="✕" Width="20" Height="20" Margin="8,0,0,0"
                                    Background="Transparent" BorderBrush="Transparent"
                                    Foreground="#9CA3AF" FontSize="11" Cursor="Hand"
                                    Click="RemoveAttachment_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1.5"
                            CornerRadius="16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.06"/>
                        </Border.Effect>
                        <Grid Margin="14,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="📎" Width="32" Height="32"
                                    Background="Transparent" BorderBrush="#E5E7EB" BorderThickness="1"
                                    Foreground="#9CA3AF" FontSize="16" Cursor="Hand"
                                    VerticalAlignment="Bottom" Click="AttachFile_Click"
                                    ToolTip="Attach file"/>
                            <TextBox Grid.Column="1" x:Name="MessageBox"
                                     Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                     Foreground="#111827" FontSize="13" FontFamily="Segoe UI"
                                     VerticalAlignment="Center" MinHeight="24" MaxHeight="120"
                                     TextWrapping="Wrap" AcceptsReturn="False"
                                     CaretBrush="#6366f1"
                                     KeyDown="MessageBox_KeyDown"
                                     TextChanged="MessageBox_TextChanged"/>
                            <TextBlock x:Name="InputPlaceholder" Grid.Column="1"
                                       Text="Ask anything about your data…"
                                       Foreground="#9CA3AF" FontSize="13" FontFamily="Segoe UI"
                                       VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <Button Grid.Column="2" x:Name="SendBtn"
                                    Width="36" Height="36" VerticalAlignment="Bottom"
                                    BorderBrush="Transparent" BorderThickness="0"
                                    Cursor="Hand" Click="SendBtn_Click" IsEnabled="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#6366f1" CornerRadius="10"
                                                Opacity="{TemplateBinding Opacity}">
                                            <TextBlock Text="↑" Foreground="White" FontSize="16" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                    <TextBlock Text="Enter to send  ·  Shift+Enter for new line"
                               FontSize="10" Foreground="#9CA3AF" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Rename modal overlay -->
        <Border x:Name="RenameOverlay" Grid.ColumnSpan="2" Visibility="Collapsed"
                Background="#4D000000">
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                    CornerRadius="14" Width="360" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.12"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Rename conversation" FontSize="14" FontWeight="Bold"
                               Foreground="#111827" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                    <TextBlock Text="Give this conversation a descriptive name."
                               FontSize="12" Foreground="#6B7280" FontFamily="Segoe UI" Margin="0,0,0,16"/>
                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1.5"
                            CornerRadius="9" Height="38" Margin="0,0,0,16">
                        <TextBox x:Name="RenameBox" Background="Transparent"
                                 BorderBrush="Transparent" BorderThickness="0"
                                 FontSize="13" FontFamily="Segoe UI" Foreground="#111827"
                                 VerticalAlignment="Center" Margin="12,0"
                                 KeyDown="RenameBox_KeyDown"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Width="80" Height="34" Margin="0,0,8,0"
                                Background="Transparent" BorderBrush="#E5E7EB" BorderThickness="1"
                                FontSize="12" Foreground="#6B7280" Cursor="Hand"
                                Click="RenameCancel_Click" FontFamily="Segoe UI"/>
                        <Button Content="Rename" Height="34" Padding="16,0"
                                Background="#6366f1" BorderBrush="Transparent" BorderThickness="0"
                                FontSize="12" FontWeight="SemiBold" Foreground="White"
                                Cursor="Hand" Click="RenameConfirm_Click" FontFamily="Segoe UI">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
