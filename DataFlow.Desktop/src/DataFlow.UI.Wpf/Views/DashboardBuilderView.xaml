<UserControl x:Class="DataFlow.UI.Wpf.Views.DashboardBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             Background="{StaticResource BgSurfaceBrush}"
             AllowDrop="True"
             Drop="OnFileDrop"
             DragOver="OnDragOver">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Padding="24,16,24,14"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Dashboard Builder" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="DatasetInfoText"
                               Text="Upload a file to begin — CSV, Excel, or PDF supported"
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ExportBtn" Content="Export PNG" Style="{StaticResource GhostButtonStyle}"
                            Margin="0,0,8,0" Click="ExportBtn_Click" IsEnabled="False"/>
                    <Button x:Name="SaveBtn" Content="Save Dashboard" Style="{StaticResource AccentButtonStyle}"
                            Click="SaveBtn_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Upload + AI prompt bar ── -->
        <Border Grid.Row="1" Padding="24,12,24,12"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Upload button -->
                <Button Grid.Column="0" x:Name="UploadBtn" Click="UploadBtn_Click"
                        Height="38" Margin="0,0,10,0"
                        Background="{StaticResource AccentBgBrush}"
                        BorderBrush="#2D2B6B" BorderThickness="1"
                        Foreground="{StaticResource AccentHoverBrush}"
                        FontFamily="Segoe UI" FontSize="13" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10" Padding="14,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="📂" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Upload File" FontFamily="Segoe UI" FontSize="13"
                                               Foreground="{StaticResource AccentHoverBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- AI prompt input -->
                <Border Grid.Column="1" Background="#141928"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="10" Height="38">
                    <Grid Margin="12,0">
                        <TextBlock x:Name="PromptPlaceholder"
                                   Text="✦  Describe the dashboard you want (e.g. 'show 4 KPIs, bar chart by category, trend line')"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <TextBox x:Name="PromptBox" Background="Transparent"
                                 BorderBrush="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 FontSize="13" FontFamily="Segoe UI"
                                 VerticalAlignment="Center"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 TextChanged="PromptBox_TextChanged"
                                 KeyDown="PromptBox_KeyDown"/>
                    </Grid>
                </Border>

                <!-- Chart type selector -->
                <ComboBox x:Name="ChartTypeCombo" Grid.Column="2"
                          Height="38" Width="130" Margin="8,0"
                          Background="#141928"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          FontFamily="Segoe UI" FontSize="12"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Auto (AI)"/>
                    <ComboBoxItem Content="Bar Chart"/>
                    <ComboBoxItem Content="Line Chart"/>
                    <ComboBoxItem Content="Pie Chart"/>
                    <ComboBoxItem Content="Scatter Plot"/>
                    <ComboBoxItem Content="KPI Cards"/>
                </ComboBox>

                <!-- Generate button -->
                <Button Grid.Column="3" x:Name="GenerateBtn"
                        Height="38" Click="GenerateBtn_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✦" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Generate" FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ── Column selectors + stats bar ── -->
        <Border Grid.Row="2" x:Name="ColumnBar" Visibility="Collapsed"
                Padding="24,10,24,10"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                Background="{StaticResource BgCardBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="X Axis:" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="XColCombo" Width="140" Height="30"
                              Background="#141928" Foreground="{StaticResource TextPrimaryBrush}"
                              BorderBrush="{StaticResource BorderBrush}"
                              FontFamily="Segoe UI" FontSize="12"
                              SelectionChanged="ColCombo_Changed"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Y Axis:" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="YColCombo" Width="140" Height="30"
                              Background="#141928" Foreground="{StaticResource TextPrimaryBrush}"
                              BorderBrush="{StaticResource BorderBrush}"
                              FontFamily="Segoe UI" FontSize="12"
                              SelectionChanged="ColCombo_Changed"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Aggregate:" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="AggCombo" Width="90" Height="30"
                              Background="#141928" Foreground="{StaticResource TextPrimaryBrush}"
                              BorderBrush="{StaticResource BorderBrush}"
                              FontFamily="Segoe UI" FontSize="12"
                              SelectedIndex="0" SelectionChanged="ColCombo_Changed">
                        <ComboBoxItem Content="Sum"/>
                        <ComboBoxItem Content="Avg"/>
                        <ComboBoxItem Content="Count"/>
                        <ComboBoxItem Content="Max"/>
                        <ComboBoxItem Content="Min"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatsText" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"/>
                </StackPanel>

                <Button Grid.Column="4" Content="Clear Data" Height="30"
                        Style="{StaticResource GhostButtonStyle}"
                        Click="ClearBtn_Click"/>
            </Grid>
        </Border>

        <!-- ── Main content: drop zone OR charts ── -->
        <Grid Grid.Row="3">

            <!-- Drop zone (shown when no data) -->
            <Border x:Name="DropZone" Margin="24"
                    Background="Transparent"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="2" CornerRadius="16">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Background="{StaticResource AccentBgBrush}" CornerRadius="20"
                            Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="📂" FontSize="32"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Drop your file here" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="or click Upload File above"
                               FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,6,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Background="{StaticResource BgCard2Brush}" CornerRadius="6"
                                Padding="10,4" Margin="4,0">
                            <TextBlock Text="CSV" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <Border Background="{StaticResource BgCard2Brush}" CornerRadius="6"
                                Padding="10,4" Margin="4,0">
                            <TextBlock Text="Excel (.xlsx)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <Border Background="{StaticResource BgCard2Brush}" CornerRadius="6"
                                Padding="10,4" Margin="4,0">
                            <TextBlock Text="PDF (via API)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Segoe UI"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Loading overlay -->
            <Border x:Name="LoadingOverlay" Visibility="Collapsed"
                    Background="#CC0A0D14" CornerRadius="0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="LoadingText" Text="Analyzing your data…"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="240" Height="4"
                                 Margin="0,16,0,0" Foreground="{StaticResource AccentBrush}"
                                 Background="#1E2640"/>
                </StackPanel>
            </Border>

            <!-- Charts grid (shown after generation) -->
            <ScrollViewer x:Name="ChartsScroll" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="16,8,16,16">
                <StackPanel x:Name="ChartsPanel"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
