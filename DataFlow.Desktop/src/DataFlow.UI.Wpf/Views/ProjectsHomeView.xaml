<UserControl x:Class="DataFlow.UI.Wpf.Views.ProjectsHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="{StaticResource BgSurfaceBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,20,28,16"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Projects" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI" />
                    <TextBlock Text="Manage datasets, dashboards, and analytics projects"
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Segoe UI" Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="+ New Project"
                        Style="{StaticResource AccentButtonStyle}"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Stats row -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="28,16,28,0"
                     x:Name="StatsRow">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Projects" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI" />
                    <TextBlock x:Name="TotalProjectsText" Text="—" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"
                               Margin="0,4,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="↑ 3" FontSize="11" Foreground="{StaticResource GreenBrush}"
                                   FontFamily="Segoe UI" />
                        <TextBlock Text=" this month" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="Active Datasets" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI" />
                    <TextBlock x:Name="TotalDatasetsText" Text="—" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource AccentHoverBrush}" FontFamily="Segoe UI"
                               Margin="0,4,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="↑ 12" FontSize="11" Foreground="{StaticResource GreenBrush}"
                                   FontFamily="Segoe UI" />
                        <TextBlock Text=" this week" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="Dashboards" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI" />
                    <TextBlock x:Name="TotalDashboardsText" Text="—" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource PurpleBrush}" FontFamily="Segoe UI"
                               Margin="0,4,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="↑ 5" FontSize="11" Foreground="{StaticResource GreenBrush}"
                                   FontFamily="Segoe UI" />
                        <TextBlock Text=" this week" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="AI Queries" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI" />
                    <TextBlock Text="1.2k" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource CyanBrush}" FontFamily="Segoe UI"
                               Margin="0,4,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="↑ 18%" FontSize="11" Foreground="{StaticResource GreenBrush}"
                                   FontFamily="Segoe UI" />
                        <TextBlock Text=" vs last month" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Filter bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="28,16,28,0">
            <TextBlock Text="All Projects" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}" FontFamily="Segoe UI"
                       VerticalAlignment="Center" Margin="0,0,16,0" />
            <Border Background="{StaticResource AccentBgBrush}"
                    BorderBrush="#2D2B6B" BorderThickness="1"
                    CornerRadius="8" Padding="12,5" Margin="0,0,8,0" Cursor="Hand">
                <TextBlock Text="All" FontSize="12" Foreground="{StaticResource AccentHoverBrush}"
                           FontFamily="Segoe UI" />
            </Border>
            <Border Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12,5" Margin="0,0,8,0" Cursor="Hand">
                <TextBlock Text="Active" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Segoe UI" />
            </Border>
            <Border Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12,5" Cursor="Hand">
                <TextBlock Text="Archived" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Segoe UI" />
            </Border>
        </StackPanel>

        <!-- Project cards grid -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="28,16,28,20">
            <WrapPanel x:Name="ProjectCardsPanel" Orientation="Horizontal" Margin="0">
                <!-- Card 1 -->
                <Border Width="300" Margin="0,0,16,16" Background="{StaticResource BgCardBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                        CornerRadius="16" Cursor="Hand">
                    <StackPanel Margin="20">
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#2B1F00" CornerRadius="10"
                                    Width="40" Height="40" HorizontalAlignment="Left">
                                <TextBlock Text="📈" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border Grid.Column="1" Background="#1A2B1A" CornerRadius="6" Padding="8,3">
                                <TextBlock Text="Active" FontSize="11"
                                           Foreground="{StaticResource GreenBrush}" FontFamily="Segoe UI" />
                            </Border>
                        </Grid>
                        <TextBlock Text="Quarterly Sales" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI" />
                        <TextBlock Text="Revenue, churn, marketing, and operational insights across all regions."
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI" Margin="0,6,0,12" TextWrapping="Wrap" />
                        <Separator Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="12" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource OrangeBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                                <TextBlock Text="Dashboards" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="8" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource CyanBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                                <TextBlock Text="Datasets" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="342" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource PurpleBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                                <TextBlock Text="Queries" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Card 2 -->
                <Border Width="300" Margin="0,0,16,16" Background="{StaticResource BgCardBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                        CornerRadius="16" Cursor="Hand">
                    <StackPanel Margin="20">
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#1A2B1A" CornerRadius="10"
                                    Width="40" Height="40" HorizontalAlignment="Left">
                                <TextBlock Text="👥" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border Grid.Column="1" Background="#1A2B1A" CornerRadius="6" Padding="8,3">
                                <TextBlock Text="Active" FontSize="11"
                                           Foreground="{StaticResource GreenBrush}" FontFamily="Segoe UI" />
                            </Border>
                        </Grid>
                        <TextBlock Text="Customer Growth" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI" />
                        <TextBlock Text="Key metrics for acquisition, retention, and lifetime value analysis."
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI" Margin="0,6,0,12" TextWrapping="Wrap" />
                        <Separator Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="6" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource OrangeBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                                <TextBlock Text="Dashboards" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="4" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource CyanBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                                <TextBlock Text="Datasets" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="189" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource PurpleBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                                <TextBlock Text="Queries" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Card 3 -->
                <Border Width="300" Margin="0,0,16,16" Background="{StaticResource BgCardBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                        CornerRadius="16" Cursor="Hand">
                    <StackPanel Margin="20">
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource AccentBgBrush}" CornerRadius="10"
                                    Width="40" Height="40" HorizontalAlignment="Left">
                                <TextBlock Text="🧪" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border Grid.Column="1" Background="#1A2B1A" CornerRadius="6" Padding="8,3">
                                <TextBlock Text="Active" FontSize="11"
                                           Foreground="{StaticResource GreenBrush}" FontFamily="Segoe UI" />
                            </Border>
                        </Grid>
                        <TextBlock Text="Product Analytics" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI" />
                        <TextBlock Text="Usage, conversion funnels, and retention analysis in one workspace."
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI" Margin="0,6,0,12" TextWrapping="Wrap" />
                        <Separator Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="8" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource OrangeBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                                <TextBlock Text="Dashboards" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="5" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource CyanBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                                <TextBlock Text="Datasets" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="521" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource PurpleBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                                <TextBlock Text="Queries" FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- New project card -->
                <Border Width="300" Margin="0,0,16,16"
                        Background="Transparent"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="16" Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                        <Border Background="{StaticResource AccentBgBrush}" CornerRadius="12"
                                Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="+" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="New Project" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center" />
                        <TextBlock Text="Create a new analytics workspace"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="Segoe UI" HorizontalAlignment="Center"
                                   Margin="0,4,0,0" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
