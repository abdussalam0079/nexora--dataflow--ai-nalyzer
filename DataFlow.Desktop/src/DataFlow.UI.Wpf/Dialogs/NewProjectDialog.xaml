<Window x:Class="DataFlow.UI.Wpf.Dialogs.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Project" Width="520" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="White" CornerRadius="16"
            BorderBrush="#E5E7EB" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.18" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="22,18,22,16"
                    BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#EEF2FF" CornerRadius="10"
                            Width="36" Height="36" Margin="0,0,12,0">
                        <TextBlock Text="📁" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="New Project" FontSize="15" FontWeight="Bold"
                                   Foreground="#111827" FontFamily="Segoe UI"/>
                        <TextBlock Text="Set up your analytics workspace"
                                   FontSize="12" Foreground="#6B7280" FontFamily="Segoe UI"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="✕" Width="30" Height="30"
                            Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                            FontSize="13" Cursor="Hand" Click="CloseBtn_Click"
                            Foreground="#6B7280" VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,18,22,8" >

                    <!-- Live Preview -->
                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                            CornerRadius="12" Padding="14,12" Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="PreviewIconBorder" Width="42" Height="42"
                                    CornerRadius="11" Margin="0,0,12,0">
                                <TextBlock x:Name="PreviewIconText" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="PreviewName" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#9CA3AF" FontFamily="Segoe UI"
                                           Text="Project name…"/>
                                <TextBlock x:Name="PreviewDesc" FontSize="12" Foreground="#9CA3AF"
                                           FontFamily="Segoe UI" Text="No description"/>
                            </StackPanel>
                            <Border Grid.Column="2" Background="White" BorderBrush="#E5E7EB"
                                    BorderThickness="1" CornerRadius="99" Padding="8,3">
                                <TextBlock Text="Preview" FontSize="11" Foreground="#9CA3AF"
                                           FontFamily="Segoe UI"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Name -->
                    <TextBlock Text="PROJECT NAME *" FontSize="10" FontWeight="Bold"
                               Foreground="#6B7280" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                            CornerRadius="10" Height="38" Margin="0,0,0,16">
                        <Grid Margin="12,0">
                            <TextBlock Text="📝" FontSize="13" VerticalAlignment="Center"
                                       Margin="0,0,8,0" HorizontalAlignment="Left"/>
                            <TextBox x:Name="NameBox" Background="Transparent"
                                     BorderBrush="Transparent" BorderThickness="0"
                                     FontSize="13" FontFamily="Segoe UI"
                                     Foreground="#111827" VerticalAlignment="Center"
                                     Margin="22,0,0,0"
                                     TextChanged="NameBox_TextChanged"/>
                        </Grid>
                    </Border>

                    <!-- Description -->
                    <TextBlock Text="DESCRIPTION" FontSize="10" FontWeight="Bold"
                               Foreground="#6B7280" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                            CornerRadius="10" Margin="0,0,0,18">
                        <TextBox x:Name="DescBox" Background="Transparent"
                                 BorderBrush="Transparent" BorderThickness="0"
                                 FontSize="13" FontFamily="Segoe UI"
                                 Foreground="#111827" Margin="12,8"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="52" MaxHeight="80"
                                 TextChanged="DescBox_TextChanged"/>
                    </Border>

                    <!-- Icon + Color row -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon picker -->
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="PROJECT ICON" FontSize="10" FontWeight="Bold"
                                       Foreground="#6B7280" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                            <WrapPanel x:Name="IconPanel"/>
                        </StackPanel>

                        <!-- Color picker -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="COLOR" FontSize="10" FontWeight="Bold"
                                       Foreground="#6B7280" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                            <UniformGrid x:Name="ColorPanel" Columns="2"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F9FAFB" BorderBrush="#E5E7EB"
                    BorderThickness="0,1,0,0" Padding="22,14" CornerRadius="0,0,16,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="ℹ" FontSize="11" Foreground="#9CA3AF" Margin="0,0,5,0"/>
                        <TextBlock Text="Projects hold datasets, dashboards &amp; chats"
                                   FontSize="11" Foreground="#9CA3AF" FontFamily="Segoe UI"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Cancel" Width="80" Height="36" Margin="0,0,8,0"
                                Background="Transparent" BorderBrush="#E5E7EB" BorderThickness="1"
                                FontSize="13" Foreground="#6B7280" Cursor="Hand"
                                Click="CloseBtn_Click" FontFamily="Segoe UI"/>
                        <Button x:Name="CreateBtn" Height="36" Padding="18,0"
                                BorderBrush="Transparent" BorderThickness="0"
                                FontSize="13" FontWeight="SemiBold" Foreground="White"
                                Cursor="Hand" Click="CreateBtn_Click" FontFamily="Segoe UI">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="15" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Create Project" FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
