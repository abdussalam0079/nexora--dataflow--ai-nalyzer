<Window x:Class="DataFlow.UI.Wpf.Dialogs.NewDashboardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Dashboard" Width="600" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">
    <Border Background="White" CornerRadius="16"
            BorderBrush="#E5E7EB" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.18" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="22,18,22,16"
                    BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#EEF2FF" CornerRadius="10" Width="36" Height="36" Margin="0,0,12,0">
                        <TextBlock Text="⊞" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6366f1"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="New Dashboard" FontSize="15" FontWeight="Bold" Foreground="#111827" FontFamily="Segoe UI"/>
                        <TextBlock Text="Configure your analytics canvas" FontSize="12" Foreground="#6B7280" FontFamily="Segoe UI"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="✕" Width="30" Height="30"
                            Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                            FontSize="13" Cursor="Hand" Click="CloseBtn_Click" Foreground="#6B7280"/>
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,18,22,8">

                    <!-- Name + Description row -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="DASHBOARD NAME *" FontSize="10" FontWeight="Bold"
                                       Foreground="#6B7280" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                            <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                                    CornerRadius="10" Height="38">
                                <TextBox x:Name="NameBox" Background="Transparent"
                                         BorderBrush="Transparent" BorderThickness="0"
                                         FontSize="13" FontFamily="Segoe UI" Foreground="#111827"
                                         VerticalAlignment="Center" Margin="12,0"/>
                            </Border>
                            <TextBlock x:Name="NameError" Text="Name is required."
                                       FontSize="11" Foreground="#EF4444" FontFamily="Segoe UI"
                                       Margin="0,4,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="DESCRIPTION" FontSize="10" FontWeight="Bold"
                                       Foreground="#6B7280" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                            <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                                    CornerRadius="10" Height="38">
                                <TextBox x:Name="DescBox" Background="Transparent"
                                         BorderBrush="Transparent" BorderThickness="0"
                                         FontSize="13" FontFamily="Segoe UI" Foreground="#111827"
                                         VerticalAlignment="Center" Margin="12,0"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Color Scheme -->
                    <TextBlock Text="COLOR SCHEME" FontSize="10" FontWeight="Bold"
                               Foreground="#6B7280" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                    <UniformGrid x:Name="SchemePanel" Columns="3" Margin="0,0,0,18"/>

                    <!-- AI Layout Generator -->
                    <StackPanel Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="⚡" FontSize="12" Foreground="#6366f1" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="AI LAYOUT GENERATOR" FontSize="10" FontWeight="Bold"
                                       Foreground="#6B7280" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            <Border Background="#EEF2FF" CornerRadius="99" Padding="8,2" Margin="8,0,0,0">
                                <TextBlock Text="Optional" FontSize="10" Foreground="#6366f1" FontFamily="Segoe UI"/>
                            </Border>
                        </StackPanel>

                        <!-- Preset chips -->
                        <WrapPanel x:Name="PresetPanel" Margin="0,0,0,10"/>

                        <!-- Prompt textarea -->
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="11">
                            <TextBox x:Name="PromptBox" Background="Transparent"
                                     BorderBrush="Transparent" BorderThickness="0"
                                     FontSize="12" FontFamily="Segoe UI" Foreground="#111827"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="72" Margin="12,10"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="ℹ" FontSize="11" Foreground="#9CA3AF" Margin="0,0,5,0"/>
                            <TextBlock Text="AI auto-generates widgets from your description. Leave blank for empty canvas."
                                       FontSize="11" Foreground="#9CA3AF" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F9FAFB" BorderBrush="#E5E7EB"
                    BorderThickness="0,1,0,0" Padding="22,14" CornerRadius="0,0,16,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔒" FontSize="11" Margin="0,0,5,0"/>
                        <TextBlock Text="Saved automatically once created"
                                   FontSize="11" Foreground="#9CA3AF" FontFamily="Segoe UI"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Cancel" Width="80" Height="36" Margin="0,0,8,0"
                                Background="Transparent" BorderBrush="#E5E7EB" BorderThickness="1"
                                FontSize="13" Foreground="#6B7280" Cursor="Hand"
                                Click="CloseBtn_Click" FontFamily="Segoe UI"/>
                        <Button x:Name="CreateBtn" Height="36" Padding="18,0"
                                Background="#6366f1" BorderBrush="Transparent" BorderThickness="0"
                                FontSize="13" FontWeight="SemiBold" Foreground="White"
                                Cursor="Hand" Click="CreateBtn_Click" FontFamily="Segoe UI">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="15" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Create Dashboard" FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
